# Copy to .env.local and fill in (never commit .env.local).

# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Resend (required for team invite emails) ---
RESEND_API_KEY=

# Optional: override default sender. If unset, app uses Resend’s test address onboarding@resend.dev (no domain setup).
# With your own domain: verify it at resend.com/domains, then e.g. RESEND_FROM="Keurio <noreply@yourdomain.com>"
# RESEND_FROM="Keurio <onboarding@resend.dev>"

# Optional: public site URL used in invite emails (Accept invite link).
# Use your real app URL in production, e.g. https://keurio.vercel.app
# If both are unset, invite links use http://localhost:3000 (bad on Vercel).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Alternative to NEXT_PUBLIC_APP_URL (same purpose; either is enough).
# NEXT_PUBLIC_SITE_URL=

# --- Anthropic (optional: AI-assisted findings on inspection run) ---
# ANTHROPIC_API_KEY=
# Optional model override (default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=
